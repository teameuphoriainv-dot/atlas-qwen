# Atlas environment — copy to .env.local and fill in.

# Qwen on Alibaba Cloud Model Studio (server-side only — never exposed to the client)
# Get a key: Alibaba Cloud console → Model Studio → API keys
QWEN_API_KEY=sk-...
# International endpoint (default). Beijing region: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Order drafting (structured tool-calls)
QWEN_MODEL=qwen-max
# Interactive agent loop (latency-sensitive)
QWEN_AGENT_MODEL=qwen-plus
# OCR of EHR screenshots (multimodal)
QWEN_VL_MODEL=qwen-vl-max

# FHIR sandbox (HAPI public R4 — open, no key, supports read + write)
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# Pinned synthetic demo patient
DEMO_PATIENT_ID=

# Flip to true to use the local mock FHIR server (demo-safe fallback)
NEXT_PUBLIC_USE_MOCK_FHIR=false
