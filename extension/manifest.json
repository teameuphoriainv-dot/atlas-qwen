{
  "manifest_version": 3,
  "name": "Atlas — EHR Copilot",
  "version": "0.2.0",
  "description": "Agentic EHR copilot: ask anything, it reads/reasons over the chart and writes (confirm-gated) via SMART-on-FHIR. Works on Epic.",
  "key": "",
  "action": {
    "default_title": "Toggle Atlas"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "identity",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://atlas-ehr-one.vercel.app/*",
    "https://fhir.epic.com/*",
    "https://*.epic.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
